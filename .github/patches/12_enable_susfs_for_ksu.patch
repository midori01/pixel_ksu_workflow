 #if defined(__x86_64__)
 #include <asm/cpufeature.h>
 #include <linux/version.h>
@@ -82,6 +89,10 @@ module_param(allow_shell, bool, 0);
 
 int __init kernelsu_init(void)
 {
+#ifdef CONFIG_KSU_SUSFS
